      "taskNumber": "MOU-3408",
      "title": "MongoDB - projít Mongo na CI/Stage/ PROD a pročistit jej od backup a testovacích kolekcí",
      "branch": "",
      "status": "hotovo",
      "script": "Duplicita\n// Aggregation pipeline to find duplicate records based on ContractVersionId\nconst pipeline = [\n  {\n    $group: {\n      _id: \"$ContractVersionId\",\n      count: { $sum: 1 },\n      ids: { $push: \"$_id\" }\n    }\n  },\n  {\n    $match: {\n      count: { $gt: 1 }\n    }\n  }\n];\n\n// Execute the aggregation\nconst duplicates = db[\"contracts-insurances-synchronization-projection\"].aggregate(pipeline);\n\n// Print the results\nduplicates.forEach((duplicate) => {\n  print(`ContractVersionId: ${duplicate._id}, Duplicate Count: ${duplicate.count}, Document IDs: ${duplicate.ids}`);\n});",
      "releaseId": "suH53iJwqm",
